# Copy to .env for local (non-Docker) runs.
DATABASE_URL=postgresql+psycopg2://vettalume:vettalume@localhost:5432/vettalume
REDIS_URL=redis://localhost:6379/0
DEV_MODE=true
# For a zero-setup local run you can instead use:
# DATABASE_URL=sqlite+pysqlite:///./vettalume.db

# Comma-separated admin emails for the content portal (/admin). Empty by default (secure).
# Accounts with these emails are admins; or bootstrap with: python -m scripts.create_admin <email> <pw>
ADMIN_EMAILS=

# --- Email (OTP, welcome, payment receipt) ---
# Transport is chosen best -> fallback: Resend, then SMTP, then dev-console print.
# Leave everything below empty for local dev: emails (incl. the OTP) print to the uvicorn console.
#
# Resend (recommended): create an API key at https://resend.com and verify your sending domain.
RESEND_API_KEY=
# From header for all mail. The domain must be verified in Resend. For a quick no-domain test use
# the Resend sandbox sender below.
MAIL_FROM=Vettalume <no-reply@vettalume.com>
# MAIL_FROM=Vettalume <onboarding@resend.dev>
#
# SMTP alternative (used only when RESEND_API_KEY is empty):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
